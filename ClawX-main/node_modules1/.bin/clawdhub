#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/clawx/ClawX-main/node_modules/.pnpm/clawhub@0.5.0/node_modules/clawhub/bin/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/clawhub@0.5.0/node_modules/clawhub/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/clawhub@0.5.0/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/clawx/ClawX-main/node_modules/.pnpm/clawhub@0.5.0/node_modules/clawhub/bin/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/clawhub@0.5.0/node_modules/clawhub/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/clawhub@0.5.0/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../clawhub/bin/clawdhub.js" "$@"
else
  exec node  "$basedir/../clawhub/bin/clawdhub.js" "$@"
fi
