else
  export NODE_PATH="/mnt/d/clawx/ClawX-main/node_modules/.pnpm/vitest@4.0.18_@types+node@2_2907d70dd52aa2071ccd942754177f1d/node_modules/vitest/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/vitest@4.0.18_@types+node@2_2907d70dd52aa2071ccd942754177f1d/node_modules:/mnt/d/clawx/ClawX-main/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vitest/vitest.mjs" "$@"
else
  exec node  "$basedir/../vitest/vitest.mjs" "$@"
fi
